# Pattern Project - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# IDENTITY
# =============================================================================
# Names used in conversation formatting and memory extraction.
# USER_NAME=Brian
# AI_NAME=Isaac

# =============================================================================
# LLM API KEYS
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (used for TTS voice synthesis)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# LLM MODEL SELECTION
# =============================================================================
# Default/fallback model for general use
# ANTHROPIC_MODEL=claude-sonnet-4-6

# User-facing conversation model
# ANTHROPIC_MODEL_CONVERSATION=claude-sonnet-4-6

# Memory extraction model
# ANTHROPIC_MODEL_EXTRACTION=claude-sonnet-4-6

# Delegation sub-agent model (lightweight tasks)
# DELEGATION_MODEL=claude-haiku-4-5-20251001

# Maximum output tokens per LLM response
# ANTHROPIC_MAX_TOKENS=64000

# =============================================================================
# WEB UI
# =============================================================================
# Authentication password for the web interface.
# Generate a strong one: openssl rand -base64 24
# Leave empty for no auth (local development only).
WEB_AUTH_PASSWORD=

# Bind address and port for the FastAPI web server.
# On a VPS behind nginx, keep these defaults.
# WEB_HOST=0.0.0.0
# WEB_PORT=8080

# =============================================================================
# LOGGING
# =============================================================================
# LOG_LEVEL=INFO

# =============================================================================
# PROMPT CACHING
# =============================================================================
# Caches stable portions of the system prompt to reduce token cost (~90%
# savings on cache hits) and latency (~85% reduction).
# PROMPT_CACHE_ENABLED=true

# =============================================================================
# FEATURE TOGGLES
# =============================================================================
# Master switches for all tool features. Each adds tools to the AI's prompt.
# Disabling unused features reduces prompt token count.
# Values: true / false (unless noted otherwise)

# Intention system — reminders, goals, plans (4 tools)
INTENTION_ENABLED=true

# Telegram messaging (1 tool) — also requires credentials below
TELEGRAM_ENABLED=true

# System pulse — idle timer self-prompting (1 tool)
SYSTEM_PULSE_ENABLED=true

# Curiosity engine — topic exploration during conversation (1 tool)
CURIOSITY_ENABLED=true

# Growth threads — long-term developmental aspirations (2 tools)
GROWTH_THREADS_ENABLED=true

# Web search — Claude's built-in web search (1 built-in tool)
WEB_SEARCH_ENABLED=true

# Web fetch — Claude's built-in page fetcher (1 built-in tool + 2 domain mgmt tools)
WEB_FETCH_ENABLED=true

# Visual capture — screenshot and webcam (up to 2 tools depending on mode)
# Values: true / false
VISUAL_ENABLED=true
# Per-source capture modes. Values: "auto", "on_demand", "disabled"
#   auto      — captures automatically every prompt, NO tool added
#   on_demand — AI requests capture via tool, tool IS added to prompt
#   disabled  — source never used, no tool added
VISUAL_SCREENSHOT_MODE=auto
VISUAL_WEBCAM_MODE=on_demand

# Image memory — save and recall images in long-term memory (1 tool)
IMAGE_MEMORY_ENABLED=true

# Novel reading — chapter-by-chapter literary ingestion (5 tools)
NOVEL_READING_ENABLED=true
# Model routing: Sonnet for per-chapter extraction, Opus for arc reflection & synthesis
NOVEL_EXTRACTION_MODEL=claude-sonnet-4-6
NOVEL_REFLECTION_MODEL=claude-opus-4-6

# Google Calendar (4 tools) — also requires credentials file below
GOOGLE_CALENDAR_ENABLED=false

# Reddit integration (8 tools) — also requires credentials below
REDDIT_ENABLED=false

# =============================================================================
# VOICE / STT CONFIGURATION
# =============================================================================
# faster-whisper model for speech-to-text. Sizes: tiny (~75MB), base (~150MB), small (~500MB)
# WHISPER_MODEL=small

# =============================================================================
# TELEGRAM CREDENTIALS
# =============================================================================
# Create a bot via @BotFather on Telegram to get your token.
# telegram_bot=
# TELEGRAM_CHAT_ID=

# =============================================================================
# REDDIT CREDENTIALS
# =============================================================================
# See docs/reddit_setup.md for full setup instructions.
# 1. Create a "script" app at https://www.reddit.com/prefs/apps
# 2. Fill in the values below
# 3. Run: python scripts/reddit_setup.py to validate
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# REDDIT_USER_AGENT=python:pattern-agent:v1.0 (by /u/your_username)

# =============================================================================
# GOOGLE CALENDAR CREDENTIALS
# =============================================================================
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Google Calendar API
# 3. Create OAuth2 credentials (Desktop app) and download the JSON
# 4. Save the JSON to data/Calendar_Google_Credentials.json
# 5. On first use, a browser opens for consent; token auto-saves and refreshes
# GOOGLE_CALENDAR_CREDENTIALS_PATH=data/Calendar_Google_Credentials.json
# GOOGLE_CALENDAR_TOKEN_PATH=data/Calendar_Google_Token.json
# GOOGLE_CALENDAR_TIMEZONE=America/New_York

# =============================================================================
# GOOGLE DRIVE BACKUP
# =============================================================================
# Backs up database + data/files/ to Google Drive (compressed .tar.gz archives).
# Each backup includes the SQLite snapshot and all user writings/journals/novels.
# Requires the Google Drive API enabled in the same Cloud project.
# Uses drive.file scope (can only see files this app created).
GOOGLE_DRIVE_BACKUP_ENABLED=false
# GOOGLE_DRIVE_BACKUP_CREDENTIALS_PATH=data/Calendar_Google_Credentials.json
# GOOGLE_DRIVE_BACKUP_TOKEN_PATH=data/Drive_Google_Token.json
# GOOGLE_DRIVE_BACKUP_FOLDER_NAME=Pattern Backups
# GOOGLE_DRIVE_BACKUP_RETENTION_COUNT=7

# =============================================================================
# GUARDIAN WATCHDOG
# =============================================================================
# External process that monitors Pattern's health and restarts on failure.
# See docs/GUARDIAN_SPEC.md and docs/VPS_SETUP_GUIDE.md (Section 7).
# GUARDIAN_ENABLED=true
# GUARDIAN_EXECUTABLE_PATH=/opt/guardian/guardian.py
# GUARDIAN_CONFIG_PATH=/opt/guardian/guardian.toml

# =============================================================================
# VPS DEPLOYMENT OVERRIDES
# =============================================================================
# When deploying to a headless VPS, disable desktop features:
# VISUAL_ENABLED=false
# VISUAL_SCREENSHOT_MODE=disabled
# VISUAL_WEBCAM_MODE=disabled
