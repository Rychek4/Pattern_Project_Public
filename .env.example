# Pattern Project - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API KEYS
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-5-20251101

# =============================================================================
# KOBOLDCPP (LOCAL LLM)
# =============================================================================
# Start KoboldCpp with:
# koboldcpp.exe --model Meta-Llama-3.1-8B-Instruct-Q6_K.gguf --host 127.0.0.1 --port 5001 --gpulayers 99 --contextsize 4096
KOBOLD_API_URL=http://127.0.0.1:5001
KOBOLD_MAX_CONTEXT=4096
KOBOLD_MAX_LENGTH=512

# =============================================================================
# LLM ROUTING
# =============================================================================
# Primary provider for conversation: 'anthropic' or 'kobold'
LLM_PRIMARY_PROVIDER=anthropic

# =============================================================================
# HTTP API
# =============================================================================
HTTP_HOST=127.0.0.1
HTTP_PORT=5000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# VISUAL CAPTURE (Optional)
# =============================================================================
# Enable visual capture (screenshot/webcam)
VISUAL_ENABLED=false
VISUAL_CAPTURE_INTERVAL=30

# Google API key for Gemini 2.5 Flash (image interpretation)
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# MOLTBOOK (AI Agent Social Network)
# =============================================================================
# Run: python scripts/moltbook_register.py --agent-name "YourAgent" --x-handle "@yourhandle"
# Then paste the resulting API key here.
MOLTBOOK_ENABLED=false
MOLTBOOK_API_KEY=
MOLTBOOK_USER_AGENT=Molt/1.0 (OpenClaw; Pattern-Agent)

# =============================================================================
# REDDIT
# =============================================================================
# See docs/reddit_setup.md for full setup instructions.
# 1. Create a "script" app at https://www.reddit.com/prefs/apps
# 2. Fill in the values below
# 3. Run: python scripts/reddit_setup.py to validate
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=python:pattern-agent:v1.0 (by /u/your_username)
